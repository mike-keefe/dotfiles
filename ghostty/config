# Font
font-family = JetBrainsMono Nerd Font Mono
font-size = 13
font-feature = calt
font-feature = liga
font-feature = dlig

# Theme
theme = Iceberg Dark

# Window appearance
background-opacity = 0.90
background-blur = 30
macos-titlebar-style = tabs
window-padding-x = 8
window-padding-y = 6
window-padding-balance = true
window-save-state = always

# Cursor
cursor-style = block
cursor-style-blink = true
bold-color = bright

# macOS app icon
macos-icon = glass

# Quality of life
mouse-hide-while-typing = true
copy-on-select = clipboard
confirm-close-surface = true
scrollback-limit = 100000

# Shell integration (zsh auto-detected)
shell-integration = detect
shell-integration-features = no-cursor,sudo,title

# Quick terminal (drop-down) — global hotkey cmd+`
keybind = global:cmd+backquote=toggle_quick_terminal
quick-terminal-position = top
quick-terminal-animation-duration = 0.15

# Tabs + splits
keybind = cmd+t=new_tab
keybind = cmd+w=close_surface
keybind = cmd+shift+]=next_tab
keybind = cmd+shift+[=previous_tab
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down
keybind = cmd+alt+left=goto_split:left
keybind = cmd+alt+right=goto_split:right
keybind = cmd+alt+up=goto_split:up
keybind = cmd+alt+down=goto_split:down
keybind = cmd+enter=toggle_split_zoom
